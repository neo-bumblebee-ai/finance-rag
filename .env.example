# ============================================================
# Core LLM + Retrieval
# ============================================================
OPENAI_API_KEY=sk-...

# Required for Cohere reranking (free tier is generous)
# Sign up: https://dashboard.cohere.com
COHERE_API_KEY=...

# ============================================================
# Auth — JWT RBAC
# ============================================================
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# In production: store in AWS Secrets Manager / Azure Key Vault
JWT_SECRET_KEY=change-me-generate-a-32-char-secret
JWT_EXPIRE_MINUTES=60

# ============================================================
# Guardrails
# ============================================================
# Set to "true" to bypass LLM guardrail checks (unit tests only)
GUARDRAILS_DISABLED=false

# ============================================================
# Observability — Langfuse (per-request cost + latency traces)
# Sign up: https://cloud.langfuse.com
# ============================================================
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================================
# Observability — LangSmith (eval tracking + cost dashboard)
# Sign up: https://smith.langchain.com
# ============================================================
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=finance-rag-production
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
